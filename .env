# Environment Configuration for Hospital Management System
# Copy this file to .env and update the values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=hospital_app
DB_PASSWORD=secure_password_change_this
DB_NAME=hospital_management_system
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=30
ENABLE_2FA=false

# Encryption Configuration
ENCRYPTION_KEY=your-32-char-encryption-key-here-xxx

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Email Configuration (REQUIRED for account recovery)
# For Gmail: Use your Gmail address and generate an App Password
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@hospital.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# API Configuration
API_VERSION=1.0.0
API_PREFIX=/api/v1

# Pagination
DEFAULT_LIMIT=20
MAX_LIMIT=100